# OpenRouter — LLM cascade (Gemma → Seed → Gemini). Required, server refuses
# to boot without it.
OPENROUTER_API_KEY=sk-or-v1-...

# Photoroom — background swap (/v2/edit). Note the /v1/segment endpoint used
# by the mask-preview flow lives on a different base (sdk.photoroom.com) and
# is hardcoded in services.js — same key works for both.
IMAGE_PROCESSING_API_URL=https://image-api.photoroom.com/v2/edit
IMAGE_PROCESSING_API_KEY=your_photoroom_key

# Claid — food-tuned image enhancement (/v1/image/edit/upload, two-hop).
CLAID_API_KEY=your_claid_key

# Express port. Frontend's VITE_API_BASE_URL must match.
PORT=3000

# CORS origin. Set to your frontend dev URL. If unset, the server boots with a
# warning and rejects all browser origins — set this explicitly rather than
# falling back to '*'.
FRONTEND_URL=http://localhost:5173
